#!/bin/bash

# define related paths
SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
IMAGE_LOAD_PATH="$(cd "$(dirname "${SCRIPT_DIR}")" && pwd)"
AGENT_JSON_PATH="${IMAGE_LOAD_PATH}/agent.json"

# Read ros2 launch configuration from agent.json
AGENT_NAME=$(jq -r '.name' "$AGENT_JSON_PATH")    # agent name is guaranteed to exist by build script

LOG_DIR="/var/log/booster_agent/${AGENT_NAME}"
ENV_DIR="/tmp/booster_agent/${AGENT_NAME}"
mkdir -p "$LOG_DIR"
mkdir -p "$ENV_DIR"
LOG_FILE="${LOG_DIR}/apprun_stop.log"
ENV_FILE="${ENV_DIR}/agent_env"

# —— add timestamp and header to log file
echo "===============================" >> "$LOG_FILE"
echo "    $(date '+%Y-%m-%d %H:%M:%S')" >> "$LOG_FILE"
echo "===============================" >> "$LOG_FILE"
echo "SCRIPT_PATH: $SCRIPT_PATH" >> "$LOG_FILE"
echo "IMAGE_LOAD_PATH: $IMAGE_LOAD_PATH" >> "$LOG_FILE"
echo "AGENT_JSON_PATH: $AGENT_JSON_PATH" >> "$LOG_FILE"

# define a logging function
log() {
  printf '%s %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$1" >> "$LOG_FILE"
}

# ERR trap：打印行号、命令、cwd，并杀掉后台 ROS
error_handler() {
  local lineno="$1"
  log "❌ ERROR in ${SCRIPT_PATH} at line ${lineno}: \`${BASH_COMMAND}\` (cwd: $(pwd))"
  [[ -n "${LAUNCH_PID:-}" ]] && kill "$LAUNCH_PID" 2>/dev/null || true
  exit 1
}
trap 'error_handler ${LINENO}' ERR

# test if env file exists
if [ ! -f "$ENV_FILE" ]; then
    echo -e "${RED}ERROR: ENV_FILE at ${ENV_FILE} not found, unexpected error${NC}"
    exit 1
fi

# read LAUNCH_PID from env file
LAUNCH_PID=$(cat "$ENV_FILE" | grep "LAUNCH_PID=" | cut -d'=' -f2)

IMAGE_EXE_PATH_PREFIX="${IMAGE_LOAD_PATH}/agent"

log "List the main process running ros2 launch:"
ps -aux | grep $LAUNCH_PID >> "$LOG_FILE"

log "List all processes in the AppImage path:"
pgrep -af $IMAGE_EXE_PATH_PREFIX >> "$LOG_FILE"

# kill ros2 launch
kill -TERM "$LAUNCH_PID" || log "❌ ERROR:Failed to terminate ros2 launch process with PID $LAUNCH_PID, it may have already exited"

# kill all processes in the AppImage path
pgrep -f $IMAGE_EXE_PATH_PREFIX | xargs kill -KILL || log "❌ ERROR:Failed to terminate processes in the AppImage path $IMAGE_LOAD_PATH, it may have already exited"

log "▶ all processes in the AppImage path terminated: $IMAGE_EXE_PATH_PREFIX"

log "List all process after termination:"
pgrep -af $IMAGE_EXE_PATH_PREFIX >> "$LOG_FILE" || true

# remove env file
rm $ENV_FILE